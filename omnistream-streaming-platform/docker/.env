# 1. GCP Infrastructure (From Terraform Output)
GCP_PROJECT_ID=de-zoomcamp-2026-486900
GCP_GCS_ERROR_BUCKET=de-zoomcamp-2026-486900-error-lake
GCP_BQ_STAGING_DS=omnistream_staging

# 2. Paths (Relative to the 'docker/' folder)
# We use '../' because 'terraform' and 'job' are outside the 'docker' folder
GCP_KEY_PATH=./key.json

# 3. Airflow & Postgres (The "Orchestra" Settings)
